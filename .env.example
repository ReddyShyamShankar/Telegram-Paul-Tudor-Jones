# cTrader Open API (Pepperstone or any cTrader broker)
# Obtain Client ID + Client Secret from https://openapi.ctrader.com/apps
# Run scripts/ctrader_oauth.py once to populate the refresh token + account id.
CTRADER_CLIENT_ID=replace-with-client-id
CTRADER_CLIENT_SECRET=replace-with-client-secret
CTRADER_REFRESH_TOKEN=replace-after-running-oauth-helper
CTRADER_ACCOUNT_ID=12345678
CTRADER_ENVIRONMENT=demo
CTRADER_HOST_DEMO=demo.ctraderapi.com
CTRADER_HOST_LIVE=live.ctraderapi.com
CTRADER_PORT=5035

# Telegram User API (Telethon)
# Get TG_API_ID + TG_API_HASH from https://my.telegram.org/apps
# TG_PHONE is your Telegram phone number in E.164 format (e.g. +919876543210).
# Run scripts/telegram_login.py once to create the session file.
# Run scripts/telegram_list_chats.py to discover channel IDs you can post to.
TG_API_ID=replace-with-numeric-api-id
TG_API_HASH=replace-with-api-hash
TG_PHONE=+15551234567
TG_SESSION_PATH=.tsg.session
TG_CHANNEL_IDS=-1001234567890,-1009876543210

# chart-img.com v2
CHART_IMG_API_KEY=replace-with-chart-img-key

# Local
TSG_DB_PATH=./data/trades.db
TSG_CACHE_DIR=./data/charts
TSG_LOG_LEVEL=INFO

# Tunables
TSG_TRACKER_INTERVAL_SECONDS=60
TSG_MAX_CONCURRENT=5
TSG_MIN_RR=3.0

# Execution layer (auto-trade on the cTrader account configured above)
TSG_ENABLE_EXECUTION=no            # 'yes' to place real orders; 'no' = signal-only
TSG_RISK_PCT=0.01                  # 0.01 = 1% of equity at risk per trade
TSG_DAILY_LOSS_R_CAP=3.0           # halt new trades after losing this many R today
TSG_ALLOW_LIVE=no                  # hard guard: 'yes' required if CTRADER_ENVIRONMENT=live
TSG_EXECUTION_MAX_LOTS=100.0       # sanity ceiling vs bug-induced over-sizing

# Signal quality gates
TSG_MISSED_ENTRY_THRESHOLD=0.3     # abort signal if current price drifted past entry by > this x SL distance
